// OmniStacks AI Engine — Prisma schema
// Foundational data model for the lead generation platform.
// Run `npm run prisma:migrate` (from the repo root) to create migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & access
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MEMBER
}

// ---------------------------------------------------------------------------
// Businesses (lead management)
// ---------------------------------------------------------------------------

model Business {
  id        String         @id @default(cuid())
  name      String
  /// Raw website URL as entered/imported
  website   String?
  /// Normalized domain derived from website (lowercase, no www/protocol/path).
  /// Uniqueness is the duplicate-prevention mechanism for imports and creates.
  domain    String?        @unique
  email     String?
  phone     String?
  industry  String?
  country   String?
  city      String?
  status    BusinessStatus @default(NEW)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tags            Tag[]
  websiteAnalyses WebsiteAnalysis[]

  @@index([status])
  @@index([industry])
  @@index([country])
  @@index([name])
  @@index([email])
  @@index([createdAt])
  @@map("businesses")
}

enum BusinessStatus {
  NEW
  ANALYZED
  AUDITED
  EMAIL_DRAFTED
  EMAIL_SENT
  RESPONDED
  MEETING_BOOKED
  CLIENT
  ARCHIVED
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  businesses Business[]

  @@map("tags")
}

// ---------------------------------------------------------------------------
// Website analysis (collects raw website data for a business — no AI, no
// scoring; see docs/ARCHITECTURE.md for the module's scope boundary)
// ---------------------------------------------------------------------------

model WebsiteAnalysis {
  id         String                @id @default(cuid())
  businessId String
  status     WebsiteAnalysisStatus @default(PENDING)

  /// business.website at the time the analysis was requested
  requestedUrl  String
  /// URL after following redirects
  finalUrl      String?
  statusCode    Int?
  redirectCount Int?

  title           String?
  metaDescription String?
  canonicalUrl    String?
  language        String?
  faviconUrl      String?

  /// { h1: string[], h2: string[], ..., h6: string[] }
  headings    Json?
  /// Open Graph meta tags, key -> content
  openGraph   Json?
  /// Twitter Card meta tags, key -> content
  twitterCard Json?
  /// Parsed application/ld+json blocks
  jsonLd      Json?

  /// { href, text }[]
  internalLinks   Json?
  externalLinks   Json?
  navigationLinks Json?
  footerLinks     Json?
  /// { src, alt }[]
  images          Json?
  /// { src, type }[]
  videos          Json?
  /// { action, method, fieldCount, fieldNames }[]
  contactForms    Json?
  /// deduplicated strings
  emails          Json?
  phones          Json?
  /// { platform, url }[]
  socialLinks     Json?
  /// detected technology names, e.g. ["WORDPRESS", "GOOGLE_ANALYTICS"]
  technologies    Json?

  screenshotPath     String?
  screenshotWidth    Int?
  screenshotHeight   Int?
  screenshotByteSize Int?
  screenshotMimeType String?

  durationMs Int?
  error      String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("website_analyses")
}

enum WebsiteAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ---------------------------------------------------------------------------
// Campaigns
// ---------------------------------------------------------------------------

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  ownerId     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner User        @relation(fields: [ownerId], references: [id])
  leads Lead[]
  jobs  ScrapeJob[]

  @@index([ownerId])
  @@index([status])
  @@map("campaigns")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Leads
// ---------------------------------------------------------------------------

model Lead {
  id          String     @id @default(cuid())
  email       String?
  fullName    String?
  company     String?
  title       String?
  website     String?
  linkedinUrl String?
  phone       String?
  source      LeadSource @default(SCRAPED)
  status      LeadStatus @default(NEW)
  score       Int?
  /// Raw enrichment payload (LLM output, scraped attributes, etc.)
  enrichment  Json?
  campaignId  String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@index([email])
  @@map("leads")
}

enum LeadSource {
  SCRAPED
  IMPORTED
  API
  MANUAL
}

enum LeadStatus {
  NEW
  ENRICHED
  QUALIFIED
  CONTACTED
  CONVERTED
  DISQUALIFIED
}

// ---------------------------------------------------------------------------
// Background jobs (consumed by apps/worker)
// ---------------------------------------------------------------------------

model ScrapeJob {
  id         String    @id @default(cuid())
  type       JobType
  status     JobStatus @default(PENDING)
  /// Job input (target URLs, search criteria, model parameters, ...)
  payload    Json?
  /// Job output persisted by the worker
  result     Json?
  error      String?
  attempts   Int       @default(0)
  campaignId String?
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status, type])
  @@index([campaignId])
  @@map("scrape_jobs")
}

enum JobType {
  SCRAPE
  ENRICH
  SCORE
  SYNC
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
