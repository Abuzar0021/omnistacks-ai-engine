# ==============================================================================
# OmniStacks AI Engine — environment variables
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=omnistacks
POSTGRES_PASSWORD=omnistacks
POSTGRES_DB=omnistacks
POSTGRES_PORT=5432

# Used by Prisma (host `localhost` for local dev; `postgres` inside Docker Compose)
DATABASE_URL=postgresql://omnistacks:omnistacks@localhost:5432/omnistacks?schema=public

# ------------------------------------------------------------------------------
# API (apps/api)
# ------------------------------------------------------------------------------
API_PORT=4000
API_CORS_ORIGIN=http://localhost:5173
# Secret used to sign auth tokens — generate with: openssl rand -hex 32
JWT_SECRET=change-me

# Website analyzer (Playwright-driven data collection — apps/api)
# PLAYWRIGHT_HEADLESS is also read by apps/worker; keep both in sync.
PLAYWRIGHT_HEADLESS=true
ANALYSIS_MAX_CONCURRENCY=2
ANALYSIS_NAVIGATION_TIMEOUT_MS=30000
ANALYSIS_STABLE_TIMEOUT_MS=5000
# Relative to apps/api regardless of the process's working directory
SCREENSHOT_STORAGE_DIR=./storage/screenshots

# Lead discovery (Google Places API "Text Search" — apps/api). Requires a
# Google Cloud project with the Places API (New) enabled and billing set up;
# billed per request past Google's monthly free credit — see docs/DEPLOYMENT.md.
GOOGLE_PLACES_API_KEY=change-me
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com
LEAD_DISCOVERY_MAX_CONCURRENCY=2

# ------------------------------------------------------------------------------
# Web (apps/web) — Vite only exposes variables prefixed with VITE_
# ------------------------------------------------------------------------------
WEB_PORT=8080
VITE_API_URL=/api

# ------------------------------------------------------------------------------
# OpenRouter (LLM gateway)
# ------------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Business audits (apps/api) — who you are and what an ideal customer looks
# like; injected into the business-audit-v1 prompt. See docs/PROMPTS.md.
BUSINESS_CONTEXT="We help small and mid-sized businesses improve their website, SEO, and online presence. Ideal customers have an outdated or underperforming website and no in-house web/marketing team."
AUDIT_MAX_CONCURRENCY=2

# Outreach (apps/api) — email drafting (email-personalization-v1, see
# docs/PROMPTS.md) and sending via n8n (see docs/N8N.md).
OUTREACH_SENDER_NAME="The OmniStacks Team"
OUTREACH_EMAIL_TEMPLATE="Hi there,\n\n{{opener}}\n\nWould you be open to a quick call this week to see if it's a fit?\n\nBest,\n{{senderName}}"
EMAIL_DRAFT_MAX_CONCURRENCY=2
# URL the API calls to trigger n8n workflows (Docker Compose overrides this to
# the service name `http://n8n:5678`; distinct from n8n's own public-facing
# WEBHOOK_URL below).
N8N_API_BASE_URL=http://localhost:5678
# Shared secret checked on both directions of the API<->n8n webhook traffic —
# generate with: openssl rand -hex 32
N8N_WEBHOOK_SECRET=change-me

# ------------------------------------------------------------------------------
# Worker (apps/worker) — Playwright-based scraping/enrichment jobs
# ------------------------------------------------------------------------------
WORKER_CONCURRENCY=2

# ------------------------------------------------------------------------------
# n8n (workflow automation)
# ------------------------------------------------------------------------------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
# Public URL n8n webhooks are reachable at (update when deploying)
WEBHOOK_URL=http://localhost:5678/
# Encryption key for stored credentials — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change-me
GENERIC_TIMEZONE=UTC
# API's address as reachable from inside the n8n container — used by workflow
# expressions ($env.API_BASE_URL) in n8n/workflows/*.json. Must equal the same
# N8N_WEBHOOK_SECRET set for the API above (see docs/N8N.md).
API_BASE_URL=http://api:4000/api
# "From" address for outreach emails sent via workflow 01 (see n8n/README.md
# for connecting the operator's own Gmail/SMTP credential in the n8n UI).
OUTREACH_FROM_EMAIL=
