{
  "name": "omnistacks-ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "OmniStacks AI Engine — production-ready AI Lead Generation platform (monorepo root)",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,worker -c blue,green,magenta \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:worker\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:worker": "npm run dev --workspace apps/worker",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "npm run prisma:generate --workspace apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "prisma:deploy": "npm run prisma:deploy --workspace apps/api",
    "prisma:studio": "npm run prisma:studio --workspace apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prettier": "^3.4.2"
  }
}
